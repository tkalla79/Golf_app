generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Player {
  id              Int       @id @default(autoincrement())
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  slug            String    @unique @db.VarChar(255)
  hcp             Decimal?  @db.Decimal(4, 1)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  loginToken      String?   @unique @map("login_token") @db.VarChar(255)
  loginTokenExpiry DateTime? @map("login_token_expiry")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  groupPlayers       GroupPlayer[]
  matchesAsP1        Match[]              @relation("player1")
  matchesAsP2        Match[]              @relation("player2")
  matchesWon         Match[]              @relation("winner")
  hallOfFame         HallOfFameEntry[]
  availabilitySlots  AvailabilitySlot[]   @relation("slotOwner")
  slotJoined         AvailabilitySlot[]   @relation("slotPairedBy")

  @@map("players")
}

model Season {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(100)
  year      Int
  status    SeasonStatus @default(DRAFT)
  config    Json?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  rounds     Round[]
  hallOfFame HallOfFameEntry[]
  photos     SeasonPhoto[]
  documents  SeasonDocument[]

  @@map("seasons")
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

model Round {
  id          Int         @id @default(autoincrement())
  seasonId    Int         @map("season_id")
  name        String      @db.VarChar(100)
  roundNumber Int         @map("round_number")
  type        RoundType   @default(ROUND_ROBIN)
  holes       Int         @default(9)
  dateStart   DateTime?   @map("date_start") @db.Date
  dateEnd     DateTime?   @map("date_end") @db.Date
  status      RoundStatus @default(DRAFT)
  config      Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  season Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  groups Group[]

  @@map("rounds")
}

enum RoundType {
  ROUND_ROBIN
  PLAYOFF
}

enum RoundStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

model Group {
  id        Int        @id @default(autoincrement())
  roundId   Int        @map("round_id")
  name      String     @db.VarChar(50)
  sortOrder Int        @default(0) @map("sort_order")
  status    GroupStatus @default(DRAFT)
  createdAt DateTime   @default(now()) @map("created_at")

  round   Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  players GroupPlayer[]
  matches Match[]

  @@map("groups")
}

enum GroupStatus {
  DRAFT
  APPROVED
  ACTIVE
  COMPLETED
}

model GroupPlayer {
  id            Int      @id @default(autoincrement())
  groupId       Int      @map("group_id")
  playerId      Int      @map("player_id")
  hcpAtStart    Decimal? @map("hcp_at_start") @db.Decimal(4, 1)
  finalPosition Int?     @map("final_position")
  createdAt     DateTime @default(now()) @map("created_at")

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([groupId, playerId])
  @@map("group_players")
}

model Match {
  id                 Int      @id @default(autoincrement())
  groupId            Int      @map("group_id")
  player1Id          Int      @map("player1_id")
  player2Id          Int      @map("player2_id")
  resultCode         String?  @map("result_code") @db.VarChar(20)
  winnerId           Int?     @map("winner_id")
  player1BigPoints   Int      @default(0) @map("player1_big_points")
  player2BigPoints   Int      @default(0) @map("player2_big_points")
  player1SmallPoints Int      @default(0) @map("player1_small_points")
  player2SmallPoints Int      @default(0) @map("player2_small_points")
  player1Birdies     Int      @default(0) @map("player1_birdies")
  player2Birdies     Int      @default(0) @map("player2_birdies")
  played             Boolean  @default(false)
  isWalkover         Boolean  @default(false) @map("is_walkover")
  notes              String?  @db.Text
  scheduledDate      DateTime? @map("scheduled_date")
  reminderSent       Boolean  @default(false) @map("reminder_sent")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player1 Player  @relation("player1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player  @relation("player2", fields: [player2Id], references: [id], onDelete: Cascade)
  winner  Player? @relation("winner", fields: [winnerId], references: [id], onDelete: SetNull)
  availabilitySlots AvailabilitySlot[]

  bracketRound    Int?     @map("bracket_round")
  bracketPosition Int?     @map("bracket_position")
  holes           Int?     @map("holes")

  @@index([groupId, bracketRound, bracketPosition])
  @@map("matches")
}

model HallOfFameEntry {
  id          Int      @id @default(autoincrement())
  playerId    Int?     @map("player_id")
  seasonId    Int?     @map("season_id")
  playerName  String   @map("player_name") @db.VarChar(200)
  seasonName  String   @map("season_name") @db.VarChar(100)
  year        Int
  photoUrl    String?  @map("photo_url") @db.VarChar(500)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@map("hall_of_fame")
}

model SeasonPhoto {
  id        Int      @id @default(autoincrement())
  seasonId  Int      @map("season_id")
  url       String   @db.VarChar(500)
  caption   String?  @db.VarChar(300)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("season_photos")
}

model SeasonDocument {
  id        Int      @id @default(autoincrement())
  seasonId  Int      @map("season_id")
  url       String   @db.VarChar(500)
  title     String   @db.VarChar(300)
  docType   String   @default("image") @map("doc_type") @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("season_documents")
}

model AvailabilitySlot {
  id         Int            @id @default(autoincrement())
  playerId   Int            @map("player_id")
  matchId    Int            @map("match_id")
  dateStart  DateTime       @map("date_start")
  dateEnd    DateTime       @map("date_end")
  status     SlotStatus     @default(OPEN)
  pairedById Int?           @map("paired_by_id")
  createdAt  DateTime       @default(now()) @map("created_at")

  player   Player  @relation("slotOwner", fields: [playerId], references: [id], onDelete: Cascade)
  pairedBy Player? @relation("slotPairedBy", fields: [pairedById], references: [id])
  match    Match   @relation(fields: [matchId], references: [id])

  @@index([matchId, status])
  @@index([playerId, matchId, status])
  @@map("availability_slots")
}

enum SlotStatus {
  OPEN
  PAIRED
  CANCELLED
}
